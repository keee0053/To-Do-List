rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      allow read: if true;
      allow create, update: if isValidTask(request.resource.data);
      allow delete: if true;
    }

    function isValidTask(data) {
      return data.keys().hasOnly([
          "done",
          "title",
          "deadline",
          "createdAt",
          "updatedAt"
        ])
        && data.done is bool
        && data.title is string
        && data.title.size() <= 200
        && data.deadline is string
        && data.deadline.size() <= 40
        && data.createdAt is number
        && data.updatedAt is number;
    }
  }
}
